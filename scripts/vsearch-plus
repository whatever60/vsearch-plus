#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
binary_path="$repo_root/build/cpp/bin/vsearch"

if [[ ! -x "$binary_path" ]]; then
  echo "Missing paired VSEARCH binary at $binary_path" >&2
  echo "Run ./scripts/build_cpp.sh first." >&2
  exit 1
fi

exec "$binary_path" "$@"
